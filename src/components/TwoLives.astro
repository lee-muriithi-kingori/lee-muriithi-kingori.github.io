---
---

<section id="domains" class="domains">
  <div class="domains-inner">
    <div class="eyebrow reveal" style="margin-bottom:3rem">05 / Two Lives</div>
    <div class="domains-grid">
      <div class="domain reveal" data-d="1">
        <div class="d-label">The Engineer</div>
        <div class="d-headline">Builds things that <em>move</em>.</div>
        <ul class="d-list">
          <li>Native Android — Kotlin, NDK / JNI, Magisk modules</li>
          <li>Systems — C, x86_64, kernel work, Linux from scratch</li>
          <li>Web — full-stack TypeScript, Next.js, Prisma, Postgres</li>
          <li>Infra — SOCKS5 tunnels, proxies, privacy-grade networking</li>
          <li>AI tooling — agent skills, prompt ops, LLM integration</li>
        </ul>
        <div class="d-foot mono">Since 2020 · Self-taught · Still shipping</div>
      </div>
      <div class="domain reveal" data-d="2">
        <div class="d-label">The Nurse</div>
        <div class="d-headline">Reads vital signs. <em>Holds steady.</em></div>
        <ul class="d-list">
          <li>BSN, Dedan Kimathi University of Technology</li>
          <li>Patient assessment · Vital signs · Clinical documentation</li>
          <li>Pharmacology basics · Wound care · Triage</li>
          <li>Infection prevention and control</li>
          <li>Quietly learning to keep humans alive while keeping systems alive</li>
        </ul>
        <div class="d-foot mono">Since 2024 · Nyeri, Kenya · Active</div>
      </div>
    </div>
  </div>
</section>

<style>
  .domains {
    padding: 8rem 0;
  }
  .domains-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .eyebrow::before {
    content: "";
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--muted);
  }
  .domains-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-top: 1px solid var(--ink);
    border-bottom: 1px solid var(--ink);
  }
  .domain {
    padding: 3.5rem 2.5rem;
    border-right: 1px solid var(--rule);
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: relative;
  }
  .domain:last-child {
    border-right: none;
    background: var(--ink);
    color: var(--ivory);
  }
  .domain:last-child .d-label { color: var(--accent); }
  .domain:last-child .d-list li { border-bottom-color: rgba(242, 237, 226, 0.1); color: rgba(242, 237, 226, 0.85); }
  .domain:last-child .d-foot { color: rgba(242, 237, 226, 0.4); }

  .d-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }
  .d-label::before {
    content: "";
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: currentColor;
    display: inline-block;
  }
  .d-headline {
    font-family: 'Fraunces', serif;
    font-variation-settings: 'opsz' 144, 'SOFT' 40, 'WONK' 1;
    font-weight: 400;
    font-size: clamp(1.6rem, 2.8vw, 2.4rem);
    line-height: 1.05;
    letter-spacing: -0.018em;
  }
  .d-headline em {
    font-style: italic;
    color: var(--accent);
    font-weight: 300;
  }
  .domain:last-child .d-headline em { color: var(--accent-3); }

  .d-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .d-list li {
    font-size: 0.95rem;
    line-height: 1.5;
    padding-bottom: 0.7rem;
    border-bottom: 1px solid var(--rule);
    display: flex;
    gap: 0.9rem;
    align-items: baseline;
  }
  .d-list li::before {
    content: "";
    display: inline-block;
    width: 5px;
    height: 5px;
    flex-shrink: 0;
    border: 1px solid currentColor;
    border-radius: 50%;
    transform: translateY(-3px);
  }
  .d-foot {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.16em;
    color: var(--muted);
    text-transform: uppercase;
  }

  .reveal {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.9s ease, transform 0.9s ease;
  }
  .reveal.in { opacity: 1; transform: translateY(0); }
  .reveal[data-d="1"] { transition-delay: 0.08s; }
  .reveal[data-d="2"] { transition-delay: 0.16s; }

  @media (max-width: 880px) {
    .domains-grid { grid-template-columns: 1fr; }
    .domain { border-right: none; border-bottom: 1px solid var(--rule); }
    .domain:last-child { border-bottom: none; }
    .domain { padding: 2.5rem 1.6rem; }
  }
</style>